        "@dhis2/app-runtime": "3.12.0",
        "@dhis2/d2-i18n": "1.1.0",
        "@dhis2/d2-i18n-extract": "1.0.8",
        "@dhis2/d2-i18n-generate": "1.2.0",
        "@dhis2/d2-ui-core": "7.3.3",
        "@dhis2/d2-ui-forms": "7.3.3",
        "@dhis2/ui": "7.16.2",
        "@dhis2/ui-core": "6.24.0",
        "@dhis2/ui-widgets": "6.24.0",
        "@eyeseetea/d2-api": "1.16.0",
        "@eyeseetea/d2-ui-components": "2.9.0",
        "@material-ui/core": "4.12.4",
        "@material-ui/icons": "4.11.3",
        "@material-ui/styles": "4.11.5",
        "@monaco-editor/react": "4.3.1",
        "argparse": "2.0.1",
        "axios": "1.18.1",
        "classnames": "2.3.1",
        "csv-writer": "1.6.0",
        "d2": "31.10.2",
        "d2-manifest": "1.0.0",
        "date-fns": "^2.29.2",
        "date-fns-tz": "^1.3.7",
        "dotenv-flow": "3.2.0",
        "font-awesome": "4.7.0",
        "human-readable": "^0.2.1",
        "js-md5": "^0.8.3",
        "lodash": "4.18.1",
        "node-html-parser": "5.1.0",
        "purify-ts": "0.16.3",
        "purify-ts-extra-codec": "0.6.0",
        "react": "17.0.2",
        "react-dom": "17.0.2",
        "styled-components": "5.3.3",
        "styled-jsx": "5.0.0",
        "ts-purify": "^3.0.5",
        "xlsx": "^0.18.5"
    },
    "resolutions": {
        "axios": "1.18.1",
        "lodash": "4.18.1"
    },
    "scripts": {
        "start": "vite",
        "prebuild": "yarn localize && yarn test",
        "build-folder": "rm -rf build/ && d2-manifest package.json manifest.webapp && vite build && yarn run manifest && cp -r i18n icon.png build",
        "build": "VITE_DEBUG='' VITE_DHIS2_BASE_URL='' VITE_DHIS2_AUTH='' yarn build-folder && rm -f $npm_package_name.zip && cd build && zip --quiet -r ../$npm_package_name.zip *",
        "build-report": "VITE_DEBUG='' VITE_DHIS2_BASE_URL='' VITE_DHIS2_AUTH='' yarn build && gulp build-report",
        "post-metadata": "VITE_DHIS2_BASE_URL='' VITE_DHIS2_AUTH='' npx ts-node -P tsconfig-cli.json src/scripts/post-metadata.ts",
        "build-tub-ou-toggle-hide": "npx ts-node -P tsconfig-cli.json src/scripts/build-tub-ou-toggle-hide.ts",
        "build-tub-ou-toggle-disable": "npx ts-node -P tsconfig-cli.json src/scripts/build-tub-ou-toggle-disable.ts",
        "build-tub-ou-toggle": "npx ts-node -P tsconfig-cli.json src/scripts/build-tub-ou-toggle.ts",
        "build-autogenerated-forms": "VITE_DEBUG='' VITE_DHIS2_BASE_URL='' VITE_DHIS2_AUTH='' ts-node src/scripts/build-autogenerated-forms.ts",
        "build-configurator-folder": "rm -rf build/ && yarn run configurator-manifest && vite build && yarn run configurator-build-manifest && cp -r i18n icon.png build && cp dist/custom-data-form.html build/",
        "build-configurator": "yarn build-autogenerated-forms && VITE_DEBUG='' VITE_DHIS2_BASE_URL='' VITE_DHIS2_AUTH='' VITE_REPORT_VARIANT=autogenerated-forms-configurator yarn build-configurator-folder && rm -f d2-autogen-configurator.zip && cd build && zip --quiet -r ../d2-autogen-configurator.zip *",
        "start-configurator": "yarn build-autogenerated-forms && cp dist/custom-data-form.html public/custom-data-form.html && VITE_REPORT_VARIANT=autogenerated-forms-configurator yarn start",
        "deploy": "npx ts-node -P tsconfig-cli.json src/scripts/deploy.ts",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "eslint src --ext .js,.jsx,.ts,.tsx",
        "prettify": "prettier \"./**/*.{js,jsx,json,css,ts,tsx}\" --write",
        "extract-pot": "yarn d2-i18n-extract -p src/ -o i18n/",
        "localize": "yarn update-po && d2-i18n-generate -n d2-autogen-forms -p ./i18n/ -o ./src/locales/",
        "update-po": "yarn extract-pot && for pofile in i18n/*.po; do msgmerge --backup=off -U $pofile i18n/en.pot; done",
        "manifest": "d2-manifest package.json build/manifest.webapp",
        "configurator-manifest": "d2-manifest package.json manifest.webapp --manifest.version=$npm_package_appVersions_configurator --manifest.name='Autogenerated Forms Configurator' --manifest.description='Autogenerated Forms Configurator'",
        "configurator-build-manifest": "d2-manifest package.json build/manifest.webapp  --manifest.version=$npm_package_appVersions_configurator --manifest.name='Autogenerated Forms Configurator' --manifest.description='Autogenerated Forms Configurator'",
        "prepare": "husky install"
    },
    "appVersions": {
        "configurator": "1.7.0"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "^6.6.3",
        "@testing-library/react": "12.1.2",
        "@types/argparse": "2.0.10",
        "@types/axios-mock-adapter": "1.10.0",
        "@types/classnames": "2.3.1",
        "@types/lodash": "4.14.177",
        "@types/material-ui": "0.21.12",
        "@types/md5": "2.3.1",
        "@types/node": "^20.11.0",
        "@types/react": "17.0.35",
        "@types/react-dom": "17.0.11",
        "@types/react-router-dom": "5.3.2",
        "@types/styled-components": "5.1.17",
        "@typescript-eslint/eslint-plugin": "5.4.0",
        "@typescript-eslint/parser": "5.4.0",
        "@vitejs/plugin-react": "^4.3.4",
        "@welldone-software/why-did-you-render": "6.2.3",
        "axios-mock-adapter": "1.20.0",
        "child_process": "1.0.2",
        "eslint": "8.2.0",
        "eslint-config-prettier": "8.3.0",
        "eslint-plugin-import": "2.25.3",
        "eslint-plugin-jsx-a11y": "6.5.1",
        "eslint-plugin-prettier": "4.0.0",
        "eslint-plugin-react": "7.27.0",
        "eslint-plugin-react-hooks": "4.3.0",
        "eslint-plugin-unused-imports": "2.0.0",
        "gulp": "4.0.2",
        "gulp-inline-source": "4.0.0",
        "gulp-replace": "1.1.3",
        "husky": "7.0.4",
        "jsdom": "^25.0.1",
        "prettier": "2.4.1",
        "ts-mockito": "^2.6.1",
        "ts-node": "10.4.0",
        "typescript": "^5.4.5",
        "vite": "^6.0.7",
        "vite-plugin-node-polyfills": "^0.28.0",
        "vite-plugin-singlefile": "^2.1.0",
        "vitest": "^3.0.0",
        "wait-on": "6.0.0"
    },
    "manifest.webapp": {
        "name": "D2 Autogenerated Forms",
        "description": "D2 Autogenerated Forms",
        "icons": {
            "48": "icon.png"
        },
        "developer": {
            "url": "https://www.eyeseetea.com/",
            "name": "EyeSeeTea team"
        },
        "activities": {
            "dhis": {
                "href": "*"
            }
        }
    }
}
